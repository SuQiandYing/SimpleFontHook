// Main hook installation.
namespace FontHooks {

static void AttachFontCreationHooks() {
    DetourAttach(&(PVOID&)orgCreateFontA, newCreateFontA);
    DetourAttach(&(PVOID&)orgCreateFontIndirectA, newCreateFontIndirectA);
    if (HookPolicy::ShouldInstallHook(HookPolicy::HookInstallPoint::CreateFontW)) {
        DetourAttach(&(PVOID&)orgCreateFontW, newCreateFontW);
    }
    if (HookPolicy::ShouldInstallHook(HookPolicy::HookInstallPoint::CreateFontIndirectW)) {
        DetourAttach(&(PVOID&)orgCreateFontIndirectW, newCreateFontIndirectW);
    }
    DetourAttach(&(PVOID&)orgCreateFontIndirectExA, newCreateFontIndirectExA);
    DetourAttach(&(PVOID&)orgCreateFontIndirectExW, newCreateFontIndirectExW);

    Utils::Trace("[DEBUG][HookInstall] FontCreation CreateFontA=on CreateFontIndirectA=on CreateFontW=%s CreateFontIndirectW=%s CreateFontIndirectExA=on CreateFontIndirectExW=on",
        HookPolicy::OnOff(HookPolicy::ShouldInstallHook(HookPolicy::HookInstallPoint::CreateFontW)),
        HookPolicy::OnOff(HookPolicy::ShouldInstallHook(HookPolicy::HookInstallPoint::CreateFontIndirectW)));
}

static void AttachRuntimeLibraryHooks() {
    DetourAttach(&(PVOID&)orgLoadLibraryW, newLoadLibraryW);
    DetourAttach(&(PVOID&)orgLoadLibraryExW, newLoadLibraryExW);
}

static void AttachCodepageConversionHooks() {
    DetourAttach(&(PVOID&)orgMultiByteToWideChar, newMultiByteToWideChar);
    DetourAttach(&(PVOID&)orgWideCharToMultiByte, newWideCharToMultiByte);

    Utils::Trace("[DEBUG][HookInstall] CodepageConversion MultiByteToWideChar=on WideCharToMultiByte=on");
}

static void AttachProfileHooks() {
    DetourAttach(&(PVOID&)orgGetPrivateProfileStringA, newGetPrivateProfileStringA);
    DetourAttach(&(PVOID&)orgGetPrivateProfileStringW, newGetPrivateProfileStringW);
    DetourAttach(&(PVOID&)orgGetPrivateProfileIntA, newGetPrivateProfileIntA);
    DetourAttach(&(PVOID&)orgGetPrivateProfileIntW, newGetPrivateProfileIntW);

    Utils::Trace("[DEBUG][HookInstall] ProfileHooks GetPrivateProfileStringA/W=on GetPrivateProfileIntA/W=on");
}

static void AttachEngineFileHooks() {
    DetourAttach(&(PVOID&)orgCreateFileA, newCreateFileA);
    DetourAttach(&(PVOID&)orgCreateFileW, newCreateFileW);
    DetourAttach(&(PVOID&)orgGetFileAttributesA, newGetFileAttributesA);
    DetourAttach(&(PVOID&)orgGetFileAttributesW, newGetFileAttributesW);
    DetourAttach(&(PVOID&)orgGetFileAttributesExA, newGetFileAttributesExA);
    DetourAttach(&(PVOID&)orgGetFileAttributesExW, newGetFileAttributesExW);
    DetourAttach(&(PVOID&)orgFindFirstFileA, newFindFirstFileA);
    DetourAttach(&(PVOID&)orgFindFirstFileW, newFindFirstFileW);

    Utils::Trace("[DEBUG][HookInstall] EngineFileHooks CreateFileA/W=on GetFileAttributesA/W=on GetFileAttributesExA/W=on FindFirstFileA/W=on");
}

