static void AttachFontDataQueryHooks() {
    DetourAttach(&(PVOID&)orgGetOutlineTextMetricsA, newGetOutlineTextMetricsA);
    DetourAttach(&(PVOID&)orgGetOutlineTextMetricsW, newGetOutlineTextMetricsW);
    DetourAttach(&(PVOID&)orgGetTextExtentPointA, newGetTextExtentPointA);
    DetourAttach(&(PVOID&)orgGetTextExtentPointW, newGetTextExtentPointW);
    DetourAttach(&(PVOID&)orgGetTextExtentPointI, newGetTextExtentPointI);
    DetourAttach(&(PVOID&)orgGetTextExtentExPointI, newGetTextExtentExPointI);
    DetourAttach(&(PVOID&)orgGetFontData, newGetFontData);
    DetourAttach(&(PVOID&)orgGetFontLanguageInfo, newGetFontLanguageInfo);
    DetourAttach(&(PVOID&)orgGetFontUnicodeRanges, newGetFontUnicodeRanges);
}

static void AttachDirectWriteHooks() {
    HMODULE hDWrite = GetModuleHandleW(L"dwrite.dll");
    if (!hDWrite) {
        Utils::Trace("[DEBUG][DWrite] initial attach skipped: dwrite.dll not loaded yet");
        return;
    }

    AttachDWriteCreateFactoryInOpenTransaction(hDWrite, "initial");
}

static void AttachHooksByCategory() {
    AttachFontCreationHooks();
    AttachRuntimeLibraryHooks();
    AttachCodepageConversionHooks();
    AttachProfileHooks();
    AttachEngineFileHooks();
    AttachTextDrawingHooks();
    AttachDcFontSelectionHooks();
    AttachGlyphOutlineHooks();
    AttachTextLayoutMetricHooks();
    AttachFontIdentityQueryHooks();
    AttachFontEnumerationHooks();
    AttachGlyphMetricSupplementHooks();
    AttachFontDataQueryHooks();
    AttachDirectWriteHooks();
}

void Install(HMODULE hModule) {
    g_hModule = hModule;
    Utils::LoadConfig(hModule);
    Utils::Trace("[TRACE] process attach module=%p exe pid=%lu", hModule, GetCurrentProcessId());
    KrkrPatchMapPrerenderedFontName();
    DetourTransactionBegin();
    DetourUpdateThread(GetCurrentThread());
    AttachHooksByCategory();
    DetourTransactionCommit();
    StartDirectWriteDelayedHookThread();
    SoftpalInstallPalFontHooks();

    // GDI+
    InstallGdiPlusHooks();

    // Launch font picker UI on a separate thread. With a saved config the picker
    // starts hidden, but the hotkey/window still exists.
    _beginthreadex(NULL, 0, FontPickerThread, hModule, 0, NULL);
}

void NotifyConfigChanged(LONG version) {
    MiraiNotifyConfigChanged(version);
    bool handledByLegacyArtemis = ArtemisLegacyNotifyConfigChanged(version);
    if (!handledByLegacyArtemis) {
        ArtemisNotifyConfigChanged(version);
    }
    MajiroNotifyConfigChanged(version);
    DxLibNotifyConfigChanged(version);
}

} // namespace FontHooks
