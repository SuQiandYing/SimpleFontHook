static void AttachGlyphOutlineHooks() {
    DetourAttach(&(PVOID&)orgGetGlyphOutlineA, newGetGlyphOutlineA);
    DetourAttach(&(PVOID&)orgGetGlyphOutlineW, newGetGlyphOutlineW);
