static const wchar_t* GetCharsetDisplayName(BYTE charset) {
    switch (charset) {
    case SHIFTJIS_CHARSET: return L"\x65E5\x6587";
    case GB2312_CHARSET: return L"\x4E2D\x6587";
    case CHINESEBIG5_CHARSET: return L"\x7E41\x4F53";
    case HANGUL_CHARSET: return L"\x97E9\x6587";
    case DEFAULT_CHARSET: return L"\x9ED8\x8BA4";
    default: return L"\x672A\x77E5";
    }
}

