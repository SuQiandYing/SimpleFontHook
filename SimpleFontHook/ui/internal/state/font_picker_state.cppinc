static HDC g_paintMemDC = NULL;
static HBITMAP g_paintBitmap = NULL;
static HBITMAP g_paintOldBitmap = NULL;
static int g_paintBitmapWidth = 0;
static int g_paintBitmapHeight = 0;

struct PickerFontCacheEntry {
    std::wstring faceName;
    int height;
    int width;
    int weight;
    BYTE charset;
    HFONT font;
    DWORD lastUsed;
};
static std::vector<PickerFontCacheEntry> g_pickerFontCache;
static DWORD g_pickerFontCacheClock = 0;
static const size_t PICKER_FONT_CACHE_LIMIT = 96;

static void ClearPickerFontCache() {
    for (const auto& entry : g_pickerFontCache) {
        if (entry.font) DeleteObject(entry.font);
    }
    g_pickerFontCache.clear();
}

static HFONT GetCachedPickerFont(const std::wstring& faceName, int height, int width, int weight, BYTE charset) {
    if (height <= 0) height = 1;
    DWORD useTick = ++g_pickerFontCacheClock;
    for (auto& entry : g_pickerFontCache) {
        if (entry.height == height && entry.width == width && entry.weight == weight &&
            entry.charset == charset && entry.faceName == faceName) {
            entry.lastUsed = useTick;
            return entry.font;
        }
    }

    HFONT font = CreateFontW(-height, width, 0, 0, weight, FALSE, FALSE, FALSE,
        charset, 0, 0, CLEARTYPE_QUALITY, 0, faceName.c_str());
    if (!font) return (HFONT)GetStockObject(DEFAULT_GUI_FONT);

    if (g_pickerFontCache.size() >= PICKER_FONT_CACHE_LIMIT) {
        size_t evictIndex = 0;
        DWORD oldest = g_pickerFontCache[0].lastUsed;
        for (size_t i = 1; i < g_pickerFontCache.size(); ++i) {
            if (g_pickerFontCache[i].lastUsed < oldest) {
                oldest = g_pickerFontCache[i].lastUsed;
                evictIndex = i;
            }
        }
        if (g_pickerFontCache[evictIndex].font) DeleteObject(g_pickerFontCache[evictIndex].font);
        g_pickerFontCache.erase(g_pickerFontCache.begin() + evictIndex);
    }

    PickerFontCacheEntry entry = {};
    entry.faceName = faceName;
    entry.height = height;
    entry.width = width;
    entry.weight = weight;
    entry.charset = charset;
    entry.font = font;
    entry.lastUsed = useTick;
    g_pickerFontCache.push_back(entry);
    return font;
}

static void ReleasePaintBuffer() {
    if (g_paintMemDC) {
        if (g_paintOldBitmap) {
            SelectObject(g_paintMemDC, g_paintOldBitmap);
            g_paintOldBitmap = NULL;
        }
        if (g_paintBitmap) {
            DeleteObject(g_paintBitmap);
            g_paintBitmap = NULL;
        }
        DeleteDC(g_paintMemDC);
        g_paintMemDC = NULL;
    }
    g_paintBitmapWidth = 0;
    g_paintBitmapHeight = 0;
}

static bool EnsurePaintBuffer(HDC hdc, int width, int height) {
    if (width <= 0 || height <= 0) return false;
    if (g_paintMemDC && g_paintBitmap &&
        g_paintBitmapWidth == width && g_paintBitmapHeight == height)
        return true;

    ReleasePaintBuffer();
    g_paintMemDC = CreateCompatibleDC(hdc);
    g_paintBitmap = CreateCompatibleBitmap(hdc, width, height);
    if (!g_paintMemDC || !g_paintBitmap) {
        ReleasePaintBuffer();
        return false;
    }
    g_paintOldBitmap = (HBITMAP)SelectObject(g_paintMemDC, g_paintBitmap);
    g_paintBitmapWidth = width;
    g_paintBitmapHeight = height;
    return true;
}

